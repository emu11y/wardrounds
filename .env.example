# WardRounds — environment variables
# Copy this file to `.env.local` (gitignored) and fill in real values.
# Only VITE_-prefixed vars are exposed to the browser bundle — never put a
# secret behind a VITE_ name.

# --- Client (safe to ship to the browser) ---
# On `main` these hold the PRODUCTION Supabase project's values.
# On `dev` they hold the TEST Supabase project's values.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-publishable-anon-key

# --- Server-side secrets (NOT in this file, NOT VITE_-prefixed) ---
# These live as Supabase project secrets (Edge Functions), never in client env:
#   CLAUDE_API_KEY            -> used by the `scan-tag` Edge Function (hospital tag scanner)
#   SUPABASE_SERVICE_ROLE_KEY -> auto-injected into Edge Functions by Supabase
# Set them with: supabase secrets set CLAUDE_API_KEY=sk-ant-...
